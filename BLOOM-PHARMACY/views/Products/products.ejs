<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="stylesheet" href="/css/style.css">
    <title>Products</title>
  </head>
  <body>
    <div class="container">

        <div class="header">
            <h2>Products</h2>
        </div>

        <div class="types">
            <% products.forEach(product => { %>
                <div class="type">
                    <%= product.name %>
                </div>
            <% }) %>
        </div>

    </div>
  </body>
</html>
